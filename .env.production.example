# ============================================================
# Anjoimob v4.0 — Environment Variables (Production)
# Copie para .env.local e preencha com as chaves reais.
# NUNCA commite o .env.local com chaves reais.
# ============================================================

# ------ Supabase ------
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_<sua-anon-key>
SUPABASE_SERVICE_ROLE_KEY=sb_secret_<sua-service-role-key>

# ------ Stripe (usar chaves Live em produção) ------
STRIPE_SECRET_KEY=sk_live_<sua-secret-key>
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_<sua-publishable-key>
STRIPE_WEBHOOK_SECRET=whsec_<seu-signing-secret>

# ------ Resend (email transacional) ------
# Requer domínio anjoimob.com verificado com SPF/DKIM
RESEND_API_KEY=re_<sua-api-key>

# ------ Gemini AI (Yara) ------
GEMINI_API_KEY=<sua-gemini-api-key>

# ------ Mercado Pago (opcional) ------
MERCADO_PAGO_ACCESS_TOKEN=<seu-access-token>

# ------ App ------
NEXT_PUBLIC_APP_URL=https://www.anjoimob.com

# ------ Segurança ------
# Gerar com: openssl rand -hex 32
JWT_SECRET=<32-chars-min-random-string>
ENCRYPTION_KEY=<64-char-hex-string-gerado-com-openssl-rand-hex-32>
# Após configurar ENCRYPTION_KEY, executar no Supabase SQL Editor:
# ALTER DATABASE postgres SET "app.encryption_key" = '<mesmo-valor-de-ENCRYPTION_KEY>';

# ------ Ollama (IA local — opcional, dev only) ------
# OLLAMA_HOST=http://localhost:11434
