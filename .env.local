# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-supabase.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Resend Configuration (Email)
RESEND_API_KEY=re_your_resend_api_key_here

# Stripe Configuration (Payments)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Gemini AI Configuration
GEMINI_API_KEY=your_gemini_api_key_here

# Mercado Pago Configuration
MERCADO_PAGO_ACCESS_TOKEN=your_mercado_pago_token_here

# Application Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Ollama Configuration (optional - for local AI)
OLLAMA_HOST=http://localhost:11434

# Security Configuration
JWT_SECRET=your_jwt_secret_key_change_in_production_32_chars_min
ENCRYPTION_KEY=your_encryption_key_32_chars_long_minimum
